; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Individual Game Jam"
run/main_scene="uid://byrnsp8747oit"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Dialogic="*uid://ds2q0uclmolvu"
SceneTransition="*uid://cvchjbplkdep8"
GameState="*uid://bdkglm21m4urf"

[dialogic]

directories/dch_directory={
"character": "res://dialogic/characters/david.dch",
"doll": "res://dialogic/characters/doll.dch",
"grandpa": "res://dialogic/characters/grandpa.dch",
"key": "res://dialogic/characters/key.dch"
}
directories/dtl_directory={
"after_letter": "res://dialogic/timelines/after_letter.dtl",
"bed_not_ready": "res://dialogic/timelines/bed_not_ready.dtl",
"broken_bridge": "res://dialogic/timelines/broken_bridge.dtl",
"doll_found": "res://dialogic/timelines/doll_found.dtl",
"door_locked": "res://dialogic/timelines/door_locked.dtl",
"ending": "res://dialogic/timelines/ending.dtl",
"enter_house": "res://dialogic/timelines/enter_house.dtl",
"opening": "res://dialogic/timelines/opening.dtl",
"opening_2": "res://dialogic/timelines/opening_2.dtl",
"opening_3": "res://dialogic/timelines/opening_3.dtl",
"opening_altar": "res://dialogic/timelines/opening_altar.dtl",
"secret_room": "res://dialogic/timelines/secret_room.dtl",
"yippie": "res://dialogic/timelines/yippie.dtl"
}
layout/style_directory={}
glossary/default_case_sensitive=true
layout/style_list=[]
layout/default_style="Default"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[global_group]

player=""
crops=""
source=""
secred_door=""

